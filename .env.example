# Database URL. Unset or comment out to use default SQLite (data/ot.db).
# For PostgreSQL (after migration):
DATABASE_URL=postgresql://otuser:password@localhost/otregister

# Optional: use a different PostgreSQL URL, e.g. with SSL or different host/port
# DATABASE_URL=postgresql://otuser:password@localhost:5432/otregister

# Telegram bot (optional – leave empty to disable the bot)
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_chat_id
